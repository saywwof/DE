<Window x:Class="VelosipedDrive.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар"
        Height="560"
        Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Arial">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Text="Товар"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#4B0082"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Артикул"/>
            <TextBox x:Name="ArticleTextBox" Height="30" Margin="0,0,0,8"/>

            <TextBlock Text="Наименование товара"/>
            <TextBox x:Name="NameTextBox" Height="30" Margin="0,0,0,8"/>

            <TextBlock Text="Категория"/>
            <TextBox x:Name="CategoryTextBox" Height="30" Margin="0,0,0,8"/>

            <TextBlock Text="Производитель"/>
            <TextBox x:Name="ManufacturerTextBox" Height="30" Margin="0,0,0,8"/>

            <TextBlock Text="Поставщик"/>
            <TextBox x:Name="SupplierTextBox" Height="30" Margin="0,0,0,8"/>

            <TextBlock Text="Цена"/>
            <TextBox x:Name="PriceTextBox" Height="30" Margin="0,0,0,8"/>

            <TextBlock Text="Единица измерения"/>
            <TextBox x:Name="UnitTextBox" Height="30" Margin="0,0,0,8"/>

            <TextBlock Text="Количество на складе"/>
            <TextBox x:Name="QuantityTextBox" Height="30" Margin="0,0,0,8"/>

            <TextBlock Text="Скидка"/>
            <TextBox x:Name="DiscountTextBox" Height="30" Margin="0,0,0,8"/>

            <TextBlock Text="Фото, например 1.jpg"/>
            <TextBox x:Name="PhotoTextBox" Height="30"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Сохранить"
                    Width="120"
                    Height="35"
                    Background="#4B0082"
                    Foreground="White"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>

            <Button Content="Отмена"
                    Width="100"
                    Height="35"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
