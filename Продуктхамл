<Window x:Class="VelosipedDrive.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Список товаров"
        Height="700"
        Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FontFamily="Arial">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="#6A5ACD" Margin="0,0,0,10">
            <Image Source="Images/icon.png"
                   Height="55"
                   Width="80"
                   Stretch="Uniform"
                   DockPanel.Dock="Left"
                   Margin="10"/>

            <TextBlock Text="ООО Велосипед Драйв — список товаров"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="10,0"/>

            <Button Content="Выход"
                    Width="100"
                    Height="32"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Margin="0,20,15,20"
                    Click="LogoutButton_Click"/>
        </DockPanel>

        <DockPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock x:Name="RoleTextBlock"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="#4B0082"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">

                <Button x:Name="AddProductButton"
                        Content="Добавить товар"
                        Width="130"
                        Height="32"
                        Margin="5,0"
                        Click="AddProductButton_Click"/>

                <Button x:Name="EditProductButton"
                        Content="Редактировать"
                        Width="130"
                        Height="32"
                        Margin="5,0"
                        Click="EditProductButton_Click"/>

                <Button x:Name="DeleteProductButton"
                        Content="Удалить"
                        Width="100"
                        Height="32"
                        Margin="5,0"
                        Click="DeleteProductButton_Click"/>

                <Button x:Name="OrdersButton"
                        Content="Заказы"
                        Width="100"
                        Height="32"
                        Margin="5,0"
                        Click="OrdersButton_Click"/>
            </StackPanel>
        </DockPanel>

        <Border x:Name="FilterPanel"
                Grid.Row="2"
                BorderBrush="#6A5ACD"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Поиск:"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0"/>

                <TextBox x:Name="SearchTextBox"
                         Width="260"
                         Height="30"
                         TextChanged="Filter_Changed"/>

                <TextBlock Text="Сортировка:"
                           VerticalAlignment="Center"
                           Margin="20,0,5,0"/>

                <ComboBox x:Name="SortComboBox"
                          Width="180"
                          Height="30"
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="По умолчанию" Tag="" IsSelected="True"/>
                    <ComboBoxItem Content="Цена ↑" Tag="price_asc"/>
                    <ComboBoxItem Content="Цена ↓" Tag="price_desc"/>
                    <ComboBoxItem Content="Количество ↑" Tag="qty_asc"/>
                    <ComboBoxItem Content="Количество ↓" Tag="qty_desc"/>
                    <ComboBoxItem Content="Скидка ↑" Tag="discount_asc"/>
                    <ComboBoxItem Content="Скидка ↓" Tag="discount_desc"/>
                </ComboBox>

                <TextBlock Text="Скидка:"
                           VerticalAlignment="Center"
                           Margin="20,0,5,0"/>

                <ComboBox x:Name="DiscountFilterComboBox"
                          Width="170"
                          Height="30"
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все диапазоны" Tag="all" IsSelected="True"/>
                    <ComboBoxItem Content="0–11,99%" Tag="0_1199"/>
                    <ComboBoxItem Content="12–18,99%" Tag="12_1899"/>
                    <ComboBoxItem Content="19% и более" Tag="19_plus"/>
                </ComboBox>

                <TextBlock x:Name="CountTextBlock"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="#4B0082"
                           Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="330"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="ProductsDataGrid"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      SelectionChanged="ProductsDataGrid_SelectionChanged"
                      LoadingRow="ProductsDataGrid_LoadingRow"/>

            <Border Grid.Column="1"
                    BorderBrush="#4B0082"
                    BorderThickness="2"
                    Margin="15,0,0,0"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="Фото товара"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#4B0082"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <Image x:Name="ProductImage"
                           Height="260"
                           Stretch="Uniform"/>

                    <TextBlock x:Name="ImageInfoTextBlock"
                               TextWrapping="Wrap"
                               Margin="0,15,0,0"
                               FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
