        private Dictionary<string, object> BuildProductValues(ProductEditWindow window)
        {
            Dictionary<string, object> values = new Dictionary<string, object>();

            AddValue(values, FindColumnName("артикул", "article"), window.Article);
            AddValue(values, FindColumnName("наименование", "name"), window.ProductName);
            AddValue(values, FindColumnName("категория", "category"), window.Category);
            AddValue(values, FindColumnName("производ", "manufacturer"), window.Manufacturer);
            AddValue(values, FindColumnName("постав", "supplier"), window.Supplier);
            AddValue(values, FindColumnName("цена", "price"), ParseDecimal(window.Price));
            AddValue(values, FindColumnName("единица", "unit"), window.Unit);
            AddValue(values, FindColumnName("колич", "склад", "quantity"), ParseDecimal(window.Quantity));
            AddValue(values, FindColumnName("скид", "discount"), ParseDecimal(window.Discount));
            AddValue(values, FindColumnName("изображ", "фото", "картин", "picture", "image"), window.Photo);

            return values;
        }

        private void AddValue(Dictionary<string, object> values, string columnName, object value)
        {
            if (string.IsNullOrWhiteSpace(columnName))
                return;

            if (!values.ContainsKey(columnName))
                values.Add(columnName, value);
        }

        private void InsertProduct(Dictionary<string, object> values)
        {
            List<string> columns = new List<string>();
            List<string> parameters = new List<string>();

            using (SqlConnection connection = new SqlConnection(Db.ConnectionString))
            {
                connection.Open();

                SqlCommand command = new SqlCommand();
                command.Connection = connection;

                int index = 0;

                foreach (KeyValuePair<string, object> pair in values)
                {
                    string parameterName = "@p" + index;

                    columns.Add(EscapeSqlColumn(pair.Key));
                    parameters.Add(parameterName);
                    command.Parameters.AddWithValue(parameterName, pair.Value ?? DBNull.Value);

                    index++;
                }

                string query = "INSERT INTO dbo.Tovar_import (" +
                               string.Join(", ", columns) +
                               ") VALUES (" +
                               string.Join(", ", parameters) +
                               ")";

                command.CommandText = query;
                command.ExecuteNonQuery();
            }
        }

        private void UpdateProduct(Dictionary<string, object> values, string oldArticle, string articleColumn)
        {
            List<string> setParts = new List<string>();

            using (SqlConnection connection = new SqlConnection(Db.ConnectionString))
            {
                connection.Open();

                SqlCommand command = new SqlCommand();
                command.Connection = connection;

                int index = 0;

                foreach (KeyValuePair<string, object> pair in values)
                {
                    string parameterName = "@p" + index;

                    setParts.Add(EscapeSqlColumn(pair.Key) + " = " + parameterName);
                    command.Parameters.AddWithValue(parameterName, pair.Value ?? DBNull.Value);

                    index++;
                }

                command.Parameters.AddWithValue("@oldArticle", oldArticle);

                string query = "UPDATE dbo.Tovar_import SET " +
                               string.Join(", ", setParts) +
                               " WHERE " + EscapeSqlColumn(articleColumn) + " = @oldArticle";

                command.CommandText = query;
                command.ExecuteNonQuery();
            }
        }

        private bool IsProductUsedInOrders(string article)
        {
            try
            {
                string orderTableName = FindTableName("заказ", "order");

                if (string.IsNullOrWhiteSpace(orderTableName))
                    return false;

                DataTable orders = Db.GetTable("SELECT * FROM dbo." + EscapeSqlTable(orderTableName));

                foreach (DataRow row in orders.Rows)
                {
                    foreach (DataColumn column in orders.Columns)
                    {
                        if (row[column] == null || row[column] == DBNull.Value)
                            continue;

                        string value = row[column].ToString();

                        if (value.Contains(article))
                            return true;
                    }
                }

                return false;
            }
            catch
            {
                return false;
            }
        }

        private string FindTableName(params string[] keywords)
        {
            DataTable tables = Db.GetTable("SELECT name FROM sys.tables");

            foreach (DataRow row in tables.Rows)
            {
                string tableName = row["name"].ToString().ToLower();

                foreach (string keyword in keywords)
                {
                    if (tableName.Contains(keyword.ToLower()))
                        return row["name"].ToString();
                }
            }

            return "";
        }

        private string EscapeSqlColumn(string columnName)
        {
            return "[" + columnName.Replace("]", "]]") + "]";
        }

        private string EscapeSqlTable(string tableName)
        {
            return "[" + tableName.Replace("]", "]]") + "]";
        }

