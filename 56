<Window x:Class="VelosipedDrive.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Список товаров"
        Height="650"
        Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FontFamily="Arial">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Background="#6A5ACD" Margin="0,0,0,10">
            <Image Source="Images/icon.png"
                   Height="55"
                   Width="80"
                   Stretch="Uniform"
                   DockPanel.Dock="Left"
                   Margin="10"/>

            <TextBlock Text="ООО Велосипед Драйв — список товаров"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="10,0"/>
        </DockPanel>

        <TextBlock x:Name="RoleTextBlock"
                   Grid.Row="1"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#4B0082"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="ProductsDataGrid"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      SelectionChanged="ProductsDataGrid_SelectionChanged"/>

            <Border Grid.Column="1"
                    BorderBrush="#4B0082"
                    BorderThickness="2"
                    Margin="15,0,0,0"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="Фото товара"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#4B0082"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <Image x:Name="ProductImage"
                           Height="260"
                           Stretch="Uniform"/>

                    <TextBlock x:Name="ImageInfoTextBlock"
                               TextWrapping="Wrap"
                               Margin="0,15,0,0"
                               FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
